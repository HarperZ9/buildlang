{
  "name": "buildlang",
  "displayName": "BuildLang",
  "description": "BuildLang language support - syntax highlighting, snippets, and bracket matching",
  "version": "1.0.5",
  "publisher": "HarperZ9",
  "repository": {
    "type": "git",
    "url": "https://github.com/HarperZ9/buildlang"
  },
  "license": "SEE LICENSE IN LICENSE",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:buildlang"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "buildlang",
        "aliases": [
          "BuildLang",
          "build"
        ],
        "extensions": [
          ".bld"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icons/build-light.png",
          "dark": "./icons/build-dark.png"
        }
      }
    ],
    "grammars": [
      {
        "language": "buildlang",
        "scopeName": "source.bld",
        "path": "./syntaxes/buildlang.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "buildlang",
        "path": "./snippets/buildlang.json"
      }
    ],
    "configuration": {
      "title": "BuildLang",
      "properties": {
        "buildlang.serverPath": {
          "type": "string",
          "default": "buildc",
          "description": "Path to the buildc compiler binary"
        },
        "buildlang.target": {
          "type": "string",
          "default": "c",
          "enum": [
            "c",
            "hlsl",
            "glsl",
            "spirv",
            "llvm",
            "wasm",
            "x86-64",
            "arm64"
          ],
          "description": "Default compilation target"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  }
}
