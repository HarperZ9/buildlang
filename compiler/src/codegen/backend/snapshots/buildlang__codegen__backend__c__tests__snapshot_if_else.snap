// Type definitions (dependency-ordered)
// String table
static const char* __str0 = "big\n";
static const char* __str1 = "small\n";

// Forward declarations
int32_t main(int argc, char** argv);

int32_t main(int argc, char** argv) {
    __build_init_io();
    build_args_init(argc, argv);
    int32_t x;
    bool _2;
    int8_t* _3;
    int8_t* _5;

    x = 10;
    _2 = (x > 5);
    if (_2) goto bb1; else goto bb2;
bb1:
    _3 = __str0;
    printf(_3);
    goto bb4;
bb2:
    _5 = __str1;
    printf(_5);
    goto bb5;
bb3:
    fflush(stdout);
    return 0;
bb4:
    goto bb3;
bb5:
    goto bb3;
}
