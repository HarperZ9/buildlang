static bool build_hmap_remove_str_f64(BuildStrF64MapHandle h, const char* key) {
    BuildStrF64Map* m = h.inner;
    uint32_t hash = __build_hash_str(key);
    size_t idx = hash % m->cap;
    size_t start = idx;
